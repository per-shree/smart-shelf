rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------
    // PROTOTYPE MODE: Allows all access. 
    // WARNING: In production, you MUST restrict this to authenticated users 
    // and implement the membership checks.
    // ------------------------------------------------------------

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Fridge Rules
    match /fridges/{fridgeId} {
      // allow get is needed for onSnapshot/doc fetching
      // allow list is needed for the query with passwordHash in login
      allow read: if true; 
      
      // Verification for create: ensure basic fields
      allow create: if true 
        && incoming().passwordHash is string 
        && incoming().passwordHash.size() > 0;
        
      allow update: if incoming().passwordHash == existing().passwordHash;

      // Products subcollection
      match /products/{productId} {
        allow read, write: if true;
      }

      // Members subcollection
      match /members/{memberId} {
        allow read, write: if true;
      }

      // Shopping List subcollection
      match /shoppingList/{itemId} {
        allow read, write: if true;
      }

      // Activity Logs subcollection
      match /activity_logs/{logId} {
        allow read, write: if true;
      }
    }
  }
}
